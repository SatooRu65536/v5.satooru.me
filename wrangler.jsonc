{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "v5-satooru-me",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"r2_buckets": [
		{
			"bucket_name": "v5-satooru-me",
			"binding": "MEDIA"
		},
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "v5-satooru-me",
			"database_id": "6379914e-e8ef-4e5d-a7f2-470a31ae0a3a"
		}
	],
}