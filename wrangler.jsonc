{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "v5-satooru-me",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"r2_buckets": [
		{
			"bucket_name": "satooru-me",
			"binding": "MEDIA"
		},
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "satooru-me",
			"database_id": "b7de037a-c0ef-4cf8-b134-46eae7d8402d",
		}
	],
}