{
  "$schema": "./seed.schema.json",
  "version": "1",
  "meta": {
    "name": "Profile Site",
    "description": "A simple profile site built with EmDash CMS.",
    "author": "SatooRu"
  },
  "settings": {
    "title": "佐藤さとる",
    "tagline": "Hi There 👋"
  },
  "collections": [
    {
      "slug": "pages",
      "label": "Pages",
      "labelSingular": "Page",
      "supports": ["drafts", "revisions", "search"],
      "fields": [
        {
          "slug": "title",
          "label": "Title",
          "type": "string",
          "required": true,
          "searchable": true
        },
        {
          "slug": "content",
          "label": "Content",
          "type": "portableText",
          "searchable": true
        }
      ]
    }
  ],
  "taxonomies": [],
  "menus": [
    {
      "name": "primary",
      "label": "Primary Navigation",
      "items": [
        {
          "type": "custom",
          "label": "Home",
          "url": "/"
        },
        {
          "type": "custom",
          "label": "About",
          "url": "/about"
        },
        {
          "type": "custom",
          "label": "Posts",
          "url": "/posts"
        },
        {
          "type": "custom",
          "label": "Research",
          "url": "/research"
        }
      ]
    },
    {
      "name": "sns",
      "label": "SNS",
      "items": [
        {
          "type": "custom",
          "label": "X",
          "url": "https://x.com/SatooRu65536"
        },
        {
          "type": "custom",
          "label": "GitHub",
          "url": "https://github.com/SatooRu65536"
        },
        {
          "type": "custom",
          "label": "Instagram",
          "url": "https://www.instagram.com/satooru65536/"
        }
      ]
    }
  ]
}
