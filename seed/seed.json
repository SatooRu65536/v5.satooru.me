{
  "$schema": "./seed.schema.json",
  "version": "1",
  "meta": {
    "name": "Profile Site",
    "description": "A simple profile site built with EmDash CMS.",
    "author": "SatooRu"
  },
  "settings": {
    "title": "佐藤さとる",
    "tagline": "Hi There 👋"
  },
  "collections": [
    {
      "slug": "pages",
      "label": "Pages",
      "labelSingular": "Page",
      "supports": ["drafts", "revisions", "search"],
      "fields": [
        {
          "slug": "title",
          "label": "Title",
          "type": "string",
          "required": true,
          "searchable": true
        },
        {
          "slug": "content",
          "label": "Content",
          "type": "portableText",
          "searchable": true
        }
      ]
    },
    {
      "slug": "works",
      "label": "Works",
      "labelSingular": "Works",
      "fields": [
        {
          "slug": "title",
          "label": "Title",
          "type": "string",
          "required": true
        },
        {
          "slug": "type",
          "label": "Type",
          "type": "select",
          "required": true,
          "options": [
            { "value": "バイト", "label": "バイト" },
            { "value": "業務委託", "label": "業務委託" },
            { "value": "短期インターン", "label": "短期インターン" },
            { "value": "長期インターン", "label": "長期インターン" },
            { "value": "就職", "label": "就職" }
          ]
        },
        {
          "slug": "start_date",
          "label": "Start Date",
          "type": "datetime",
          "required": true
        },
        {
          "slug": "end_date",
          "label": "End Date",
          "type": "datetime",
          "required": false
        },
        {
          "slug": "summary",
          "label": "Summary",
          "type": "string",
          "required": true
        }
      ]
    }
  ],
  "taxonomies": [],
  "menus": [
    {
      "name": "primary",
      "label": "Primary Navigation",
      "items": [
        {
          "type": "custom",
          "label": "Home",
          "url": "/"
        },
        {
          "type": "custom",
          "label": "About",
          "url": "/about"
        },
        {
          "type": "custom",
          "label": "Posts",
          "url": "/posts"
        },
        {
          "type": "custom",
          "label": "Research",
          "url": "/research"
        }
      ]
    },
    {
      "name": "sns",
      "label": "SNS",
      "items": [
        {
          "type": "custom",
          "label": "X",
          "url": "https://x.com/SatooRu65536"
        },
        {
          "type": "custom",
          "label": "GitHub",
          "url": "https://github.com/SatooRu65536"
        },
        {
          "type": "custom",
          "label": "Instagram",
          "url": "https://www.instagram.com/satooru65536/"
        }
      ]
    }
  ]
}
