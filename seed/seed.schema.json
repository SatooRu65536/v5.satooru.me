{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emdashcms.com/seed.schema.json",
  "title": "EmDash seed file",
  "description": "Seed file format for bootstrapping an EmDash site.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Path or URL to the JSON Schema describing this file."
    },
    "version": {
      "type": "string",
      "const": "1",
      "description": "Seed format version."
    },
    "meta": {
      "$ref": "#/$defs/seedMeta"
    },
    "settings": {
      "$ref": "#/$defs/siteSettings"
    },
    "collections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/seedCollection"
      }
    },
    "taxonomies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/seedTaxonomy"
      }
    },
    "menus": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/seedMenu"
      }
    },
    "redirects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/seedRedirect"
      }
    },
    "widgetAreas": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/seedWidgetArea"
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/seedSection"
      }
    },
    "bylines": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/seedByline"
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/seedContentEntries"
      }
    }
  },
  "required": ["version"],
  "additionalProperties": false,
  "$defs": {
    "slugPattern": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "seedMeta": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "author": { "type": "string" }
      },
      "additionalProperties": false
    },
    "siteSettings": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "tagline": { "type": "string" },
        "logo": { "$ref": "#/$defs/mediaReference" },
        "favicon": { "$ref": "#/$defs/mediaReference" },
        "url": { "type": "string" },
        "postsPerPage": { "type": "number" },
        "dateFormat": { "type": "string" },
        "timezone": { "type": "string" },
        "social": {
          "type": "object",
          "properties": {
            "twitter": { "type": "string" },
            "github": { "type": "string" },
            "facebook": { "type": "string" },
            "instagram": { "type": "string" },
            "linkedin": { "type": "string" },
            "youtube": { "type": "string" }
          },
          "additionalProperties": false
        },
        "seo": { "$ref": "#/$defs/seoSettings" }
      },
      "additionalProperties": false
    },
    "seoSettings": {
      "type": "object",
      "properties": {
        "titleSeparator": { "type": "string" },
        "defaultOgImage": { "$ref": "#/$defs/mediaReference" },
        "robotsTxt": { "type": "string" },
        "googleVerification": { "type": "string" },
        "bingVerification": { "type": "string" }
      },
      "additionalProperties": false
    },
    "mediaReference": {
      "type": "object",
      "properties": {
        "mediaId": { "type": "string" },
        "alt": { "type": "string" },
        "url": { "type": "string" },
        "contentType": { "type": "string" },
        "width": { "type": "number" },
        "height": { "type": "number" }
      },
      "required": ["mediaId"],
      "additionalProperties": false
    },
    "seedCollection": {
      "type": "object",
      "properties": {
        "slug": { "$ref": "#/$defs/slugPattern" },
        "label": { "type": "string" },
        "labelSingular": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "supports": {
          "type": "array",
          "items": {
            "enum": [
              "drafts",
              "revisions",
              "preview",
              "scheduling",
              "search",
              "seo"
            ]
          }
        },
        "urlPattern": { "type": "string" },
        "commentsEnabled": { "type": "boolean" },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/seedField"
          }
        }
      },
      "required": ["slug", "label", "fields"],
      "additionalProperties": false
    },
    "seedField": {
      "type": "object",
      "properties": {
        "slug": { "$ref": "#/$defs/slugPattern" },
        "label": { "type": "string" },
        "type": {
          "enum": [
            "string",
            "text",
            "url",
            "number",
            "integer",
            "boolean",
            "datetime",
            "select",
            "multiSelect",
            "portableText",
            "image",
            "file",
            "reference",
            "json",
            "slug",
            "repeater"
          ]
        },
        "required": { "type": "boolean" },
        "unique": { "type": "boolean" },
        "searchable": { "type": "boolean" },
        "defaultValue": {},
        "validation": { "type": "object" },
        "widget": { "type": "string" },
        "options": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["value", "label"],
                "additionalProperties": false,
                "properties": {
                  "value": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string"
                  }
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        }
      },
      "required": ["slug", "label", "type"],
      "additionalProperties": false
    },
    "seedTaxonomy": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "$ref": "#/$defs/slugPattern" },
        "label": { "type": "string" },
        "labelSingular": { "type": "string" },
        "hierarchical": { "type": "boolean" },
        "collections": {
          "type": "array",
          "items": { "type": "string" }
        },
        "locale": { "type": "string" },
        "translationOf": { "type": "string" },
        "terms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/seedTaxonomyTerm"
          }
        }
      },
      "required": ["name", "label", "hierarchical", "collections"],
      "additionalProperties": false
    },
    "seedTaxonomyTerm": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "slug": { "$ref": "#/$defs/slugPattern" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "parent": { "type": "string" },
        "locale": { "type": "string" },
        "translationOf": { "type": "string" }
      },
      "required": ["slug", "label"],
      "additionalProperties": false
    },
    "seedMenu": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "$ref": "#/$defs/slugPattern" },
        "label": { "type": "string" },
        "locale": { "type": "string" },
        "translationOf": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/seedMenuItem"
          }
        }
      },
      "required": ["name", "label", "items"],
      "additionalProperties": false
    },
    "seedMenuItem": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": {
          "enum": ["custom", "page", "post", "taxonomy", "collection"]
        },
        "label": { "type": "string" },
        "url": { "type": "string" },
        "ref": { "type": "string" },
        "collection": { "type": "string" },
        "target": { "enum": ["_blank", "_self"] },
        "titleAttr": { "type": "string" },
        "cssClasses": { "type": "string" },
        "locale": { "type": "string" },
        "translationOf": { "type": "string" },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/seedMenuItem"
          }
        }
      },
      "required": ["type"],
      "allOf": [
        {
          "if": {
            "properties": {
              "type": { "const": "custom" }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["url"]
          }
        },
        {
          "if": {
            "properties": {
              "type": { "enum": ["page", "post"] }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["ref"]
          }
        }
      ],
      "additionalProperties": false
    },
    "seedRedirect": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "pattern": "^/(?!/)[^\\r\\n]*$"
        },
        "destination": {
          "type": "string",
          "pattern": "^/(?!/)[^\\r\\n]*$"
        },
        "type": { "enum": [301, 302, 307, 308] },
        "enabled": { "type": "boolean" },
        "groupName": {
          "type": ["string", "null"]
        }
      },
      "required": ["source", "destination"],
      "additionalProperties": false
    },
    "seedWidgetArea": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "widgets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/seedWidget"
          }
        }
      },
      "required": ["name", "label", "widgets"],
      "additionalProperties": false
    },
    "seedWidget": {
      "type": "object",
      "properties": {
        "type": { "enum": ["content", "menu", "component"] },
        "title": { "type": "string" },
        "content": {
          "type": "array",
          "items": { "$ref": "#/$defs/portableTextNode" }
        },
        "menuName": { "type": "string" },
        "componentId": { "type": "string" },
        "props": { "type": "object" }
      },
      "required": ["type"],
      "allOf": [
        {
          "if": {
            "properties": {
              "type": { "const": "menu" }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["menuName"]
          }
        },
        {
          "if": {
            "properties": {
              "type": { "const": "component" }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["componentId"]
          }
        }
      ],
      "additionalProperties": false
    },
    "seedSection": {
      "type": "object",
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "content": {
          "type": "array",
          "items": { "$ref": "#/$defs/portableTextNode" }
        },
        "source": { "enum": ["theme", "import"] }
      },
      "required": ["slug", "title", "content"],
      "additionalProperties": false
    },
    "seedByline": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "isGuest": { "type": "boolean" }
      },
      "required": ["id", "slug", "displayName"],
      "additionalProperties": false
    },
    "seedContentEntries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/seedContentEntry"
      }
    },
    "seedContentEntry": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "slug": { "type": "string" },
        "status": { "enum": ["published", "draft"] },
        "data": { "type": "object" },
        "taxonomies": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "bylines": {
          "type": "array",
          "items": { "$ref": "#/$defs/seedBylineCredit" }
        },
        "locale": { "type": "string" },
        "translationOf": { "type": "string" }
      },
      "required": ["id", "slug", "data"],
      "allOf": [
        {
          "if": {
            "properties": {
              "translationOf": { "type": "string" }
            },
            "required": ["translationOf"]
          },
          "then": {
            "required": ["locale"]
          }
        }
      ],
      "additionalProperties": false
    },
    "seedBylineCredit": {
      "type": "object",
      "properties": {
        "byline": { "type": "string" },
        "roleLabel": { "type": "string" }
      },
      "required": ["byline"],
      "additionalProperties": false
    },
    "portableTextNode": {
      "type": "object",
      "properties": {
        "_type": { "type": "string" },
        "_key": { "type": "string" }
      },
      "required": ["_type"],
      "additionalProperties": true
    }
  }
}
