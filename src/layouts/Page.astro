---
import { getSiteSettings } from 'emdash';
import { EmDashHead } from 'emdash/ui';
import { createPublicPageContext } from 'emdash/page';
import { GoogleFontsOptimizer } from 'astro-google-fonts-optimizer';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import applyTheme from '../scripts/apply-theme?raw';
import baseStyles from '../styles/base.css?raw';
import '../styles/globals.scss';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const { title, description, image, type = 'website' } = Astro.props;
const settings = await getSiteSettings();
const siteTitle = settings?.title || 'My Profile';
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const siteDescription = settings?.tagline || 'Design & Development';

const pageCtx = createPublicPageContext({
  Astro,
  kind: 'custom',
  pageType: type,
  title: fullTitle,
  pageTitle: title ?? siteTitle,
  description: description || siteDescription,
  canonical: Astro.url.href,
  image,
  seo: { ogImage: image },
  siteName: siteTitle,
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>{fullTitle}</title>
    <EmDashHead page={pageCtx} />
    <GoogleFontsOptimizer
      url="https://fonts.googleapis.com/css2?family=Inter:wght@200;400;500;700&display=swap"
    >
      <link
        href="/rss.xml"
        rel="alternate"
        title={`${siteTitle} RSS Feed`}
        type="application/rss+xml"
      />
      <script is:inline set:html={applyTheme} />
    </GoogleFontsOptimizer>
    <style is:inline set:html={baseStyles}></style>
  </head>

  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script src="../scripts/theme-switcher.ts"></script>
  </body>
</html>
