---
import ThemeSwitcher from './shared/ThemeSwitcher.astro';
import { getMenu, getSiteSettings } from 'emdash';
import icon from '@/assets/icon.webp';

const settings = await getSiteSettings();
const name = settings?.title || 'My Profile';
const siteLogo = settings.logo;

const menu = await getMenu('primary');

interface Props {
  fixed?: boolean;
}

const { fixed = false } = Astro.props;
---

<input type="checkbox" class="hamberger-check" id="hamburger" />

<header class="header" data-fixed={fixed}>
  <a href="/" class="title-container">
    <img
      class="logo-img"
      src={siteLogo?.url ?? icon.src}
      alt={siteLogo?.alt || name}
    />
    <h3 class="title">{name}</h3>
  </a>

  <nav class="nav">
    {
      menu?.items.map((l) => (
        <a class="link" href={l.url}>
          {l.label}
        </a>
      ))
    }
  </nav>

  <ThemeSwitcher />

  <div class="hamburger-menu">
    <label class="hamburger-icon" for="hamburger">
      <div class="line"></div>
      <div class="line"></div>
      <div class="line"></div>
    </label>
  </div>
</header>

<div class="hamberger-drawer">
  <div class="menu">
    <label class="close" for="hamburger"></label>

    <ul>
      {
        menu?.items.map((l) => (
          <li>
            <a href={l.url}>{l.label}</a>
          </li>
        ))
      }
    </ul>
  </div>

  <label class="menu-bg" for="hamburger"></label>
</div>

<style lang="scss">
  .header {
    height: $header-height;
    padding-inline: 40px;

    background-color: rgba($color: $color-background, $alpha: 0.5);
    backdrop-filter: blur(4px);

    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: $space-md;
    align-items: center;

    overflow-x: hidden;
    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    z-index: $z-top;

    @include tablet {
      padding-inline: 20px;
      grid-template-columns: 1fr auto auto;
    }

    .title-container {
      display: flex;
      align-items: center;
      gap: $space-sm;

      .logo-img {
        height: 40px;
        background-color: $color-white;
        border-radius: $radius-full;
      }

      .title {
        font-size: $font-size-lg;
        font-weight: normal;
        color: $color-text;

        @include mobile {
          font-size: $font-size-base;
        }
      }
    }

    .nav {
      display: flex;
      gap: $space-md;

      @include tablet {
        display: none;
      }

      .link {
        color: $color-text;
        transition: color $transition-fast;

        &:hover {
          color: $color-accent;
        }
      }
    }
  }

  .hamberger-check {
    display: none;
  }

  .hamburger-menu {
    height: 20px;
    width: 30px;

    .hamburger-icon {
      height: 100%;
      width: 100%;
      display: block;
      position: relative;
      cursor: pointer;

      & > .line {
        height: 2px;
        width: 100%;
        background-color: $color-text;
        position: absolute;
        transition: all 0.3s;
      }

      & > .line:nth-child(1) {
        top: 0px;
      }
      & > .line:nth-child(2) {
        top: 9px;
      }
      & > .line:nth-child(3) {
        top: 18px;
      }
    }
  }

  .hamberger-drawer {
    .menu {
      width: min(100vw, 300px);
      height: 100vh;
      background-color: $color-background;
      position: fixed;
      top: 0;
      right: 0;
      z-index: 1100;
      transform: translateX(100%);
      transition: all 0.3s;

      .close {
        height: 40px;
        display: block;
        position: relative;
        cursor: pointer;

        &::before,
        &::after {
          content: '';
          height: 2px;
          width: 20px;
          background-color: $color-text;
          position: absolute;
          left: 10px;
          top: 17px;
        }

        &::before {
          rotate: 45deg;
        }
        &::after {
          rotate: -45deg;
        }
      }

      ul {
        padding: 20px 0px 10px 20px;
      }

      li {
        padding: 10px 0;
        list-style: none;
        position: relative;
        cursor: pointer;

        a {
          color: $color-text;
          text-decoration: none;
          display: inline-block;
          width: 100%;
          position: relative;
          padding-left: 0;
          transition: color 0.3s;

          &:hover {
            color: $color-text;
            padding-left: 15px;

            &::before {
              content: '';
              height: 6px;
              width: 10px;
              background-color: $color-text;
              position: absolute;
              left: 0;
              top: calc(50% - 3px);
              clip-path: polygon(0% 0, 100% 50%, 0% 100%, 0 100%);
              animation: roll 0.5s;
            }
          }
        }
      }
    }

    .menu-bg {
      height: 100vh;
      width: 100vw;
      position: fixed;
      top: 0;
      left: 0;
      z-index: 1000;
      background-color: rgba(0, 0, 0, 0);
      pointer-events: none;
      transition: background-color 0.3s;
    }
  }

  .hamberger-check:checked {
    ~ .header .hamburger-icon {
      .line:nth-child(1) {
        rotate: 45deg;
        top: 9px;
      }
      .line:nth-child(2) {
        opacity: 0;
      }
      .line:nth-child(3) {
        rotate: -45deg;
        top: 9px;
      }
    }

    ~ .hamberger-drawer {
      .menu {
        transform: translateX(0%);
      }
      .menu-bg {
        background-color: rgba(0, 0, 0, 0.5);
        pointer-events: all;
      }
    }
  }

  @keyframes roll {
    0% {
      transform: rotateX(0deg);
    }
    100% {
      transform: rotateX(540deg);
    }
  }

  @keyframes roll {
    0% {
      transform: rotateX(0deg);
    }
    100% {
      transform: rotateX(540deg);
    }
  }
</style>
