---
import { getMenu, getSiteSettings } from 'emdash';

const settings = await getSiteSettings();
const name = settings?.title || 'My Profile';
const siteLogo = settings?.logo?.url
  ? (settings.logo as { mediaId: string; alt?: string; url: string })
  : null;

const menu = await getMenu('primary');

interface Props {
  fixed?: boolean;
}

const { fixed = false } = Astro.props;
---

<header class="header" data-fixed={fixed}>
  <a href="/" class="title_container">
    <a class="site-title" href="/">
      {
        siteLogo && (
          <img
            alt={siteLogo.alt || name}
            class="site-logo-img"
            src={siteLogo.url}
          />
        )
      }
    </a>
    <h3 class="title">{name}</h3>
  </a>

  <nav class="nav">
    {
      menu?.items.map((l) => (
        <a class="link" href={l.url}>
          {l.label}
        </a>
      ))
    }
  </nav>
</header>

<style lang="scss">
  .header {
    height: $header-height;
    padding-inline: 40px;

    background-color: rgba($color: $color-background, $alpha: 0.5);
    backdrop-filter: blur(4px);

    display: flex;
    gap: $space-md;
    align-items: center;

    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    z-index: $z-top;

    @include mobile {
      padding-inline: 20px;
    }

    .title_container {
      display: contents;

      .icon {
        height: 40px;
      }

      .title {
        font-size: $font-size-lg;
        font-weight: normal;
        color: $color-text;

        @include mobile {
          font-size: $font-size-base;
        }
      }
    }

    .nav {
      display: flex;
      gap: $space-md;

      .link {
        color: $color-text;
        transition: color $transition-fast;

        &:hover {
          color: $color-accent;
        }
      }
    }
  }
</style>
