---
import { Image } from 'emdash/ui';
import penguinImg from '@/assets/penguin.webp';

interface Props {
  src: string | undefined;
  hovered?: boolean;
  class?: string;
}

const { src, hovered, class: className, ...rest } = Astro.props;
---

<div class:list={['thumbnail', className]} {...rest}>
  <Image class="image" image={src ?? penguinImg.src} data-hovered={hovered} />
</div>

<style lang="scss">
  .thumbnail {
    width: 100%;
    height: 300px;
    overflow: hidden;
    position: relative;

    .image {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover;
      transition: transform 0.5s ease;
      cursor: pointer;

      &:hover,
      &[data-hovered='true'] {
        transform: scale(1.05);
      }
    }
  }
</style>
