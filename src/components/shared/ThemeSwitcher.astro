---
import LightModeIcon from '@/components/icons/common/LightModeIcon.astro';
import DarkModeIcon from '@/components/icons/common/DarkModeIcon.astro';
---

<div class="theme-switcher">
  <button
    aria-label="Light mode"
    class="theme-btn"
    data-theme="light"
    type="button"
  >
    Light
    <LightModeIcon />
  </button>
  <button
    aria-label="Dark mode"
    class="theme-btn"
    data-theme="dark"
    type="button"
  >
    Dark
    <DarkModeIcon />
  </button>

  <script src="@/scripts/theme-switcher.ts"></script>
</div>

<style lang="scss">
  .theme-switcher {
    overflow: hidden;

    .theme-btn {
      align-items: center;
      gap: $space-sm;
      padding: $space-sm $space-md;
      border-radius: $radius-lg;
      background-color: transparent;
      color: currentColor;
      cursor: pointer;

      display: none;

      &.active {
        display: none;
      }
    }

    &:has(.theme-btn.active) {
      .theme-btn:not(.active) {
        display: flex;
      }
    }

    &:not(:has(.theme-btn.active)) {
      .theme-btn {
        @media (prefers-color-scheme: light) {
          &[data-theme='dark'] {
            display: flex;
          }
        }

        @media (prefers-color-scheme: dark) {
          &[data-theme='light'] {
            display: flex;
          }
        }
      }
    }
  }
</style>
