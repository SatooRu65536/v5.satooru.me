---
import SectionLayout from '@/layouts/SectionLayout.astro';
import dayjs from 'dayjs';
import FadeIn from '@/components/shared/FadeIn.astro';
import ListItem from '@/components/ListItem.astro';
import { getEmDashCollection } from 'emdash';
import FadeInWithStagger from '@/components/shared/FadeInWithStagger.astro';

const { entries: works, cacheHint } = await getEmDashCollection('works', {
  orderBy: {
    start_date: 'asc',
    end_date: 'asc',
  },
});

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
---

<SectionLayout title="Works" center>
  <FadeInWithStagger>
    <ul class="works">
      {
        works.map(({ data }) => (
          <FadeIn direction="left" stagger>
            <ListItem
              title={data.title}
              type={data.type}
              date={[
                dayjs(data.start_date),
                data.end_date == undefined ? undefined : dayjs(data.end_date),
              ]}
              description={data.summary}
            />
          </FadeIn>
        ))
      }
    </ul>
  </FadeInWithStagger>
</SectionLayout>

<style lang="scss">
  .works {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
</style>
